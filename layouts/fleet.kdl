// claude-fleet layout — ONE zellij session, one pane, the whole control plane.
//
// claude-fleet opens the Projects picker; pick a project → Master Claude or the
// session grid → your sessions. Each project has its own hidden tmux server.
// No more per-project zellij sessions — just this one.
//
//     zellij --layout fleet attach -c fleet
//
// If zellij can't find `claude-fleet`, use the absolute path
// (e.g. command="/Users/you/.local/bin/claude-fleet").

layout {
    tab name="fleet" {
        pane command="claude-fleet"
    }
}
