// claude-fleet v2 layout — the recommended setup.
//
// One tab, one pane, running the claude-fleet grid. All your Claude sessions
// for this zellij session live *inside* that pane (held by a hidden tmux
// server), and you select a card to drop into one.
//
// Launch, one per project (the session name scopes the fleet + tmux socket):
//     zellij --layout fleet attach -c superkey
//     zellij --layout fleet attach -c getmycoi
//
// If zellij can't find `claude-fleet`, use the absolute path
// (e.g. command="/Users/you/.local/bin/claude-fleet").

layout {
    tab name="fleet" {
        pane command="claude-fleet"
    }
}
