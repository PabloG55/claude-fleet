// claude-fleet — example zellij layout.
//
// Each tab pins a checkout (cwd) and runs `claude-here <slot>` instead of bare
// `claude`, so re-attaching this zellij session — or rebuilding it after a full
// exit — resumes the conversation that was in each tab.
//
// Install (install.sh links this into ~/.config/zellij/layouts/), then launch:
//     zellij --layout superkey attach -c superkeyv2
//
// Edit the cwd paths, tab names, and slot args to match your own checkouts.
// If zellij can't find `claude-here`, replace it with the absolute path
// (e.g. command="/Users/you/.local/bin/claude-here").

layout {
    tab name="claude" cwd="/Users/pgarces/superkey/superkey" {
        pane command="claude-here" {
            args "claude"
        }
    }
    tab name="claude 2" cwd="/Users/pgarces/superkey/superkey-1" {
        pane command="claude-here" {
            args "claude 2"
        }
    }
    tab name="claude 3" cwd="/Users/pgarces/superkey/superkey-2" {
        pane command="claude-here" {
            args "claude 3"
        }
    }
}
