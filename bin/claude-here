#!/usr/bin/env bash
# claude-here — launch Claude Code *resuming* the conversation that belongs to
# this zellij slot / checkout, instead of a blank `claude`.
#
# Used as the pane command in a zellij layout (see layouts/superkey.kdl) so that
# re-attaching a zellij session — or rebuilding it after a full exit — brings
# every conversation back where it was, in the right checkout.
#
# Usage:  claude-here [slot] [-- extra claude args...]
#   slot  a stable per-tab label (e.g. "claude 2") recorded by the hook so the
#         exact session can be matched back. Optional; falls back to cwd.

FLEET_DIR="${CLAUDE_FLEET_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}/fleet}"
PROJECTS="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects"

slot=""
if [ $# -gt 0 ] && [ "$1" != "--" ]; then
  slot="$1"; shift
fi
[ "${1:-}" = "--" ] && shift
[ -n "$slot" ] && export CLAUDE_FLEET_SLOT="$slot"

# Start sessions in bypass ("yolo") mode by default so they don't stop for
# permission prompts — matches how the fleet is meant to run. Opt out with
# CLAUDE_FLEET_YOLO=0.
YOLO=()
case "${CLAUDE_FLEET_YOLO:-1}" in
  0|false|no|off) ;;
  *) YOLO=(--dangerously-skip-permissions) ;;
esac

# A parallel session (grid `N`) is a deliberately NEW conversation in this dir —
# never resume, even if the checkout already has one.
case "${CLAUDE_FLEET_FRESH:-0}" in
  1|true|yes|on) echo "claude-here: fresh parallel session in $PWD" >&2; exec claude "${YOLO[@]}" "$@" ;;
esac

enc="$(printf '%s' "$PWD" | sed 's#[/.]#-#g')"
dir="$PROJECTS/$enc"

# a transcript is only resumable if it has a real turn — an empty/aborted
# session makes `claude --resume/--continue` error out ("No conversation found").
has_turns() { grep -qE '"type":[[:space:]]*"(user|assistant)"' "$1" 2>/dev/null; }

resume_id=""

# 1) exact match: the most recent session for this (zellij session + slot)
if [ -n "$slot" ] && [ -n "${ZELLIJ_SESSION_NAME:-}" ] && command -v jq >/dev/null 2>&1; then
  shopt -s nullglob
  best_ts=0
  for f in "$FLEET_DIR"/*.json; do
    IFS=$'\t' read -r z s id ts < <(
      jq -r '[.zellij, .slot, .session_id, (.ts//0)] | @tsv' "$f" 2>/dev/null)
    [ "$z" = "$ZELLIJ_SESSION_NAME" ] && [ "$s" = "$slot" ] || continue
    if [ "${ts:-0}" -gt "$best_ts" ]; then best_ts="$ts"; resume_id="$id"; fi
  done
fi
# drop the slot match if its transcript is gone or empty (so we don't error out)
if [ -n "$resume_id" ] && ! { [ -f "$dir/$resume_id.jsonl" ] && has_turns "$dir/$resume_id.jsonl"; }; then
  resume_id=""
fi

# 2) else the newest REAL conversation in this cwd
if [ -z "$resume_id" ] && [ -d "$dir" ]; then
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    if has_turns "$f"; then resume_id="$(basename "$f" .jsonl)"; break; fi
  done < <(ls -t "$dir"/*.jsonl 2>/dev/null)
fi

# 3) resume if we found a real one; otherwise start FRESH in this dir
if [ -n "$resume_id" ]; then
  echo "claude-here: resuming $resume_id in $PWD" >&2
  exec claude "${YOLO[@]}" --resume "$resume_id" "$@"
fi
echo "claude-here: no resumable conversation in $PWD — starting fresh" >&2
exec claude "${YOLO[@]}" "$@"
