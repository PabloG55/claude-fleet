#!/usr/bin/env bash
# fleet-read [-s SOCKET] <session> [n]
#
# Print the last n (default 1) assistant messages from a sibling session's
# transcript — so a lead session can check a worker's progress/output.
set -uo pipefail

SOCK="${CLAUDE_FLEET_SOCK:-}"
if [ "${1:-}" = "-s" ]; then SOCK="${2:-}"; shift 2; fi
SESSION="${1:-}"; N="${2:-1}"
[ -n "$SESSION" ] || { echo "fleet-read: usage: fleet-read [-s socket] <session> [n]" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "fleet-read: jq required" >&2; exit 1; }

CFG="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
FLEET_DIR="${CLAUDE_FLEET_DIR:-$CFG/fleet}"

# locate the session's transcript via its status file (newest for that slot)
tr="$(for f in "$FLEET_DIR"/*.json; do
  jq -r --arg s "$SESSION" 'select(.slot==$s)|[(.ts//0),(.transcript//"")]|@tsv' "$f" 2>/dev/null
done | sort -rn | head -1 | cut -f2)"

[ -n "$tr" ] && [ -f "$tr" ] || { echo "fleet-read: no transcript for '$SESSION'" >&2; exit 1; }

tail -n 600 "$tr" \
  | jq -r 'select(.type=="assistant") | (.message.content // []) | map(select(.type=="text")|.text) | join(" ")' 2>/dev/null \
  | grep -v '^[[:space:]]*$' | tail -n "$N"
