#!/usr/bin/env bash
# fleet-spawn <name> [--branch <b>] [--from <ref>] [--prompt "<task>"] [--reuse <wt>|--new]
#
# Create a git worktree off the current repo and start a FRESH parallel fleet
# session in it, in the background (no attach). Optionally hand it an initial
# prompt. Lets a "lead" session spin up workers on new branches/worktrees.
#
# REUSE BEFORE PROLIFERATE: if free worktrees already exist (idle, no session,
# clean), creating yet another one is almost never what you want. So spawn will
# STOP and list them rather than silently make a new one — reuse one with
# --reuse, or say --new if you really want a fresh worktree. (See fleet-worktrees.)
#
#   name    session + worktree dir name (worktree = <repo-parent>/<name>)
#   --branch  branch to use (default: <name>); created if it doesn't exist
#   --from    base ref for a new branch. Respects LOCAL commits: bases off your
#             local ref (use HEAD for the current one) and only falls back to the
#             remote tip when local is strictly BEHIND its upstream (warns if ahead).
#   --prompt  initial task to send once the session boots (~7s later)
#   --model   model for the new session (e.g. opus); default = account default
#   --reuse   start the session in an EXISTING free worktree (name or path). Alone,
#             it keeps the worktree's current branch; add --branch/--from to CLEAN
#             it (reset --hard) and rebranch in one step — how leads recycle.
#   --new     force-create a new worktree even if free ones exist
#
# A fresh worktree gets the main checkout's node_modules symlinked in (so workers
# can run lint/typecheck/tests); opt out with CLAUDE_FLEET_LINK_NM=0.
set -uo pipefail

NAME=""; BRANCH=""; BRANCH_SET=0; FROM=""; PROMPT=""; MODEL=""; REUSE=""; NEW=0
while [ $# -gt 0 ]; do
  case "$1" in
    --branch) BRANCH="${2:?}"; BRANCH_SET=1; shift 2 ;;
    --from)   FROM="${2:?}";   shift 2 ;;
    --prompt) PROMPT="${2:?}"; shift 2 ;;
    --model)  MODEL="${2:?}";  shift 2 ;;
    --reuse)  REUSE="${2:?}";  shift 2 ;;
    --new)    NEW=1;           shift ;;
    -*) echo "fleet-spawn: unknown option $1" >&2; exit 1 ;;
    *)  [ -z "$NAME" ] && { NAME="$1"; shift; } || { echo "fleet-spawn: unexpected arg $1" >&2; exit 1; } ;;
  esac
done
[ -n "$NAME" ] || { echo "fleet-spawn: usage: fleet-spawn <name> [--branch b] [--from ref] [--prompt \"...\"]" >&2; exit 1; }

SOCK="${CLAUDE_FLEET_SOCK:-}"
[ -n "$SOCK" ] || { echo "fleet-spawn: no fleet socket (run inside a fleet session, or export CLAUDE_FLEET_SOCK)" >&2; exit 1; }
command -v git  >/dev/null 2>&1 || { echo "fleet-spawn: git required"  >&2; exit 1; }
command -v tmux >/dev/null 2>&1 || { echo "fleet-spawn: tmux required" >&2; exit 1; }

GITROOT="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)" \
  || { echo "fleet-spawn: not inside a git repo" >&2; exit 1; }
WT="$(dirname "$GITROOT")/$NAME"       # sibling worktree, matches the <proj>/<name> layout
PARENT="$(dirname "$GITROOT")"
CFG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"

# ROUTE BY OWNING PROJECT — the worker MUST land on the fleet of the project this
# repo belongs to, NOT whatever socket we happened to be called with. Otherwise
# orchestrating several projects from one session (or a stale CLAUDE_FLEET_SOCK in
# the env) spawns e.g. superkey/getmycoi workers onto the claude-fleet fleet, so
# their status/nudges report to the wrong project. A worktree's project ROOT is the
# parent of its repo (siblings live under it); match that against the projects
# configs and switch to the owner's socket + config dir. No match → keep ambient.
route_to_owner() {
  local root="$1" cfg got name prof osock ocfg
  [ -n "$root" ] || return 0
  for cfg in "$HOME/.config/claude-fleet/projects" "$HOME"/.config/claude-fleet/projects.*; do
    [ -f "$cfg" ] || continue
    got="$(awk -F'\t' -v r="$root" -v home="$HOME" '
      /^[[:space:]]*#/ || NF<2 { next }
      { p=$2; sub(/^~/, home, p); if (p==r) { print $1 "\t" ($3==""?"work":$3); exit } }' "$cfg")"
    [ -n "$got" ] && break
  done
  [ -n "$got" ] || return 0                                   # unknown repo → keep ambient (safe)
  name="${got%%	*}"; prof="${got##*	}"
  case "$prof" in work|default) osock="cf-$name"; ocfg="$HOME/.claude" ;; *) osock="cf-$prof-$name"; ocfg="$HOME/.claude-$prof" ;; esac
  if [ "$osock" != "$SOCK" ]; then
    echo "fleet-spawn: this repo belongs to '$name' (fleet $osock) — routing the worker there, not the ambient $SOCK" >&2
    SOCK="$osock"; CFG_DIR="$ocfg"
  fi
}
route_to_owner "$(dirname "$GITROOT")"

# who's live where — so we can tell free worktrees from occupied ones (same test
# as fleet-worktrees: a worktree is FREE = no live session on it + clean tree).
panes="$(tmux -L "$SOCK" list-panes -a -F '#{pane_current_path}	#{session_name}' 2>/dev/null)"
sess_for() {
  local wt="$1" p s
  while IFS=$'\t' read -r p s; do
    [ -n "$p" ] || continue
    case "$p" in "$wt"|"$wt"/*) echo "$s"; return ;; esac
  done <<EOF
$panes
EOF
}
free_worktrees() {                     # "<basename> (<branch>, clean)" per free worktree
  local first=1
  git -C "$GITROOT" worktree list --porcelain 2>/dev/null | awk '
    /^worktree /{ if(wt!=""&&!skip)print wt"\t"br; wt=substr($0,10); br="(detached)"; skip=0 }
    /^branch / { b=$2; sub("refs/heads/","",b); br=b }
    /^bare$/   { skip=1 }
    /^$/       { if(wt!=""&&!skip){print wt"\t"br; wt=""} }
    END        { if(wt!=""&&!skip)print wt"\t"br }
  ' | while IFS=$'\t' read -r wt br; do
        [ -n "$wt" ] || continue
        [ "$first" = 1 ] && { first=0; continue; }                          # skip main checkout
        [ -z "$(sess_for "$wt")" ] || continue                              # occupied
        [ -z "$(git -C "$wt" status --porcelain 2>/dev/null)" ] || continue # dirty -> not free
        printf '%s (%s, clean)\n' "${wt##*/}" "$br"
      done
}

# Resolve --from to a concrete base ref, RESPECTING LOCAL commits. Echoes the ref
# on stdout (warnings on stderr); empty --from -> "" (git uses current HEAD).
#   local behind & not ahead -> the remote tip (don't start stale), warn
#   local ahead (unpushed)   -> your LOCAL ref (has commits the remote lacks), warn
#   HEAD / sha / tag / no upstream / in sync / diverged -> the ref as given, local
resolve_base() {
  local from="$1" ref up lr ahead behind
  [ -n "$from" ] || return 0
  if [ "$from" != HEAD ] && ! git -C "$GITROOT" show-ref --verify --quiet "refs/heads/$from"; then
    echo "$from"; return 0                               # sha / tag / remote ref -> as-is
  fi
  ref="$from"; [ "$from" = HEAD ] && ref="$(git -C "$GITROOT" symbolic-ref --quiet --short HEAD 2>/dev/null)"
  [ -n "$ref" ] || { echo "$from"; return 0; }           # detached HEAD -> as-is
  up="$(git -C "$GITROOT" rev-parse --abbrev-ref --symbolic-full-name "$ref@{u}" 2>/dev/null)"
  [ -n "$up" ] || { echo "$ref"; return 0; }             # no upstream -> local
  git -C "$GITROOT" fetch --quiet "${up%%/*}" "${up#*/}" 2>/dev/null || true
  lr="$(git -C "$GITROOT" rev-list --count --left-right "$ref...$up" 2>/dev/null)"
  ahead="${lr%%	*}"; behind="${lr##*	}"; ahead="${ahead:-0}"; behind="${behind:-0}"
  if [ "$behind" -gt 0 ] && [ "$ahead" -eq 0 ]; then
    echo "fleet-spawn: local $ref is $behind behind $up — basing on the remote tip ($up); 'git pull' to catch local up" >&2
    echo "$up"
  elif [ "$ahead" -gt 0 ]; then
    echo "fleet-spawn: local $ref is $ahead ahead of $up (unpushed) — basing on your LOCAL $ref, not the remote" >&2
    echo "$ref"
  else
    echo "$ref"
  fi
}

# Symlink the source checkout's node_modules into a fresh worktree so workers can
# run lint/typecheck/tests (a new worktree has none). Opt out: CLAUDE_FLEET_LINK_NM=0.
link_node_modules() {
  local wt="$1"
  case "${CLAUDE_FLEET_LINK_NM:-1}" in 0|off|no|false) return 0 ;; esac
  [ -e "$wt/node_modules" ] && return 0                  # worktree already has its own
  [ -d "$GITROOT/node_modules" ] || return 0             # nothing to link
  ln -s "$GITROOT/node_modules" "$wt/node_modules" 2>/dev/null \
    && echo "fleet-spawn: linked node_modules from the main checkout so tests/lint run (opt out: CLAUDE_FLEET_LINK_NM=0)" >&2
}

# --- resolve the worktree: reuse an existing free one, or create a new one -----
if [ -n "$REUSE" ]; then
  case "$REUSE" in /*) WT="$REUSE" ;; *) WT="$PARENT/$REUSE" ;; esac
  git -C "$GITROOT" worktree list --porcelain 2>/dev/null | grep -qxF "worktree $WT" \
    || { echo "fleet-spawn: '$REUSE' is not a worktree of this repo — see: fleet-worktrees" >&2; exit 1; }
  s="$(sess_for "$WT")"
  [ -z "$s" ] || { echo "fleet-spawn: worktree '$REUSE' is busy (session '$s'); pick a FREE one (fleet-worktrees)" >&2; exit 1; }
  if [ "$BRANCH_SET" = 1 ] || [ -n "$FROM" ]; then       # recycle: clean + rebranch in one step
    [ -n "$BRANCH" ] || BRANCH="$NAME"
    base="$(resolve_base "$FROM")"
    git -C "$WT" reset --hard >/dev/null 2>&1
    git -C "$WT" clean -fd   >/dev/null 2>&1
    if git -C "$GITROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
      git -C "$WT" checkout "$BRANCH" >&2 || exit 1
    else
      git -C "$WT" checkout -b "$BRANCH" ${base:+"$base"} >&2 || exit 1
    fi
    echo "fleet-spawn: recycled $WT onto '$BRANCH'${base:+ (from $base)}" >&2
  else
    BRANCH="$(git -C "$WT" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    echo "fleet-spawn: reusing worktree $WT (branch $BRANCH)" >&2
  fi
elif [ -e "$WT" ]; then
  echo "fleet-spawn: $WT already exists — reusing it" >&2
  BRANCH="$(git -C "$WT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "${BRANCH:-$NAME}")"
else
  [ -n "$BRANCH" ] || BRANCH="$NAME"
  # about to CREATE a new worktree — reuse a free one first if any exist (unless --new)
  if [ "$NEW" != 1 ]; then
    fw="$(free_worktrees)"
    if [ -n "$fw" ]; then
      { echo "fleet-spawn: free worktree(s) available — reuse one instead of making another:"
        printf '%s\n' "$fw" | sed 's/^/  /'
        echo "  Reuse:    fleet-spawn $NAME --reuse <worktree>"
        echo "  Recycle:  fleet-spawn $NAME --reuse <worktree> --branch <new> --from origin/main"
        echo "  New:      fleet-spawn $NAME --new"; } >&2
      exit 1
    fi
  fi
  if git -C "$GITROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
    git -C "$GITROOT" worktree add "$WT" "$BRANCH" >&2 || exit 1
  else
    base="$(resolve_base "$FROM")"
    git -C "$GITROOT" worktree add "$WT" -b "$BRANCH" ${base:+"$base"} >&2 || exit 1
  fi
fi

link_node_modules "$WT"

# unique session name on this fleet's socket
name="$NAME"; i=2
while tmux -L "$SOCK" has-session -t "$name" 2>/dev/null; do name="$NAME~$i"; i=$((i + 1)); done

# CF-3: clear any STALE park marker for this name (namespaced + legacy bare) so the
# fresh session doesn't boot "parked" off a marker left by a killed same-named one.
rm -f "${CLAUDE_FLEET_DIR:-$CFG_DIR/fleet}/$SOCK.$name.parked" \
      "${CLAUDE_FLEET_DIR:-$CFG_DIR/fleet}/$name.parked" 2>/dev/null

# fresh session in the worktree, background (lead keeps working)
tmux -L "$SOCK" new-session -d -s "$name" -c "$WT" \
  -e "CLAUDE_CONFIG_DIR=$CFG_DIR" -e "CLAUDE_FLEET_SOCK=$SOCK" -e "CLAUDE_FLEET_FRESH=1" \
  -e "CLAUDE_FLEET_MODEL=$MODEL" \
  "exec claude-here \"$name\""
echo "fleet-spawn: started '$name' in $WT (branch $BRANCH)"

# record what this worktree is for, so fleet-worktrees (and a lead that restarted
# and lost its memory) can see intent without guessing. Keyed by worktree path.
MANIFEST="${CLAUDE_FLEET_DIR:-$CFG_DIR/fleet}/$SOCK.manifest.tsv"
mkdir -p "$(dirname "$MANIFEST")" 2>/dev/null
task="${PROMPT:--}"; task="$(printf '%s' "$task" | tr '\n\r\t' '   ' | cut -c1-200)"
mtmp="$MANIFEST.$$.tmp"
{ [ -f "$MANIFEST" ] && awk -F'\t' -v w="$WT" '$1!=w' "$MANIFEST"
  printf '%s\t%s\t%s\t%s\n' "$WT" "$name" "$BRANCH" "$task"; } >"$mtmp" 2>/dev/null \
  && mv -f "$mtmp" "$MANIFEST" 2>/dev/null || rm -f "$mtmp" 2>/dev/null

# optional initial prompt — dispatch once the worker's Claude is actually READY for
# input, NOT after a fixed delay: v2.1 boot can take a minute+, and a prompt sent
# before the input box exists is silently dropped (the worker then just sits idle).
# Poll the pane for the input prompt / status bar, then fleet-send. Background so the
# lead isn't blocked; falls back to sending after ~3min if no marker ever appears.
if [ -n "$PROMPT" ]; then
  nohup bash -c '
    sock="$1"; name="$2"; msg="$3"
    for _ in $(seq 1 90); do
      tmux -L "$sock" capture-pane -p -t "$name" 2>/dev/null \
        | grep -qE "❯|bypass permissions|for shortcuts" && break
      sleep 2
    done
    sleep 1
    fleet-send -s "$sock" "$name" "$msg"
  ' _ "$SOCK" "$name" "$PROMPT" >/dev/null 2>&1 &
  echo "fleet-spawn: will dispatch the initial prompt once '$name' is ready for input"
fi
