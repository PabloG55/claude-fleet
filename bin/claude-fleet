#!/usr/bin/env bash
# claude-fleet — the single control plane for parallel Claude Code sessions.
# Run it as the one pane in your zellij session:
#
#   Projects  →  ⏎  →  Master Claude  →  C-a s  →  the session grid
#
# Each project has its own hidden tmux server (cf-<project>) holding its sessions.
# Node draws the screens; tmux does the PTY work. From master, ` (or C-a g) steps
# back to Projects; from the grid it steps back to master.
#
#   claude-fleet                 project picker (work profile)
#   claude-fleet <profile>       a separate profile — its own projects list
#                                (projects.<profile>) + config dir (~/.claude-<profile>)
#   claude-fleet <project>       jump straight into a known work project's Master Claude
#   claude-fleet <project> --plain   one-shot non-interactive list (for scripts)
set -uo pipefail

# Resolve this script through the ~/.local/bin symlink to find the repo root.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  target="$(readlink "$src")"
  case "$target" in /*) src="$target" ;; *) src="$(dirname "$src")/$target" ;; esac
done
BIN_DIR="$(cd "$(dirname "$src")" && pwd)"
REPO="$(cd "$BIN_DIR/.." && pwd)"
GRID="$BIN_DIR/fleet-grid.mjs"
CONF="$REPO/tmux/cf.tmux.conf"

command -v node  >/dev/null 2>&1 || { echo "claude-fleet: node is required"; exit 1; }
command -v tmux  >/dev/null 2>&1 || { echo "claude-fleet: tmux is required (brew install tmux)"; exit 1; }

US=$'\x1f'
PROJECTS_CFG="$HOME/.config/claude-fleet/projects"
# wipe the main screen + scrollback so tmux's "[detached …]" lines / stray frames
# don't pile up between screens
_clear() { printf '\033[2J\033[3J\033[H' >/dev/tty 2>/dev/null || true; }
TM() { tmux -L "$SOCK" -f "$CONF" "$@"; }

profile_dir() { case "$1" in work|default|"") echo "$HOME/.claude" ;; *) echo "$HOME/.claude-$1" ;; esac; }
proj_field() { awk -F'\t' -v n="$1" -v f="$2" '$1==n{print $f; exit}' "$PROJECTS_CFG" 2>/dev/null; }

ensure_projects() {
  [ -f "$PROJECTS_CFG" ] && return 0
  mkdir -p "$(dirname "$PROJECTS_CFG")" 2>/dev/null
  cat > "$PROJECTS_CFG" <<'EOF'
# claude-fleet projects — one per line:  name<TAB>path<TAB>profile
# profile: work (~/.claude) or personal (~/.claude-personal).
# Add from the picker ("+ add project"), or edit here, e.g.:
#   myapp<TAB>~/code/myapp<TAB>work
EOF
}

# select a project: export everything the grid/hooks/sessions key off
set_project() {
  PROJECT="$1"
  PROJECT_ROOT="$(proj_field "$PROJECT" 2)"; PROJECT_ROOT="${PROJECT_ROOT/#\~/$HOME}"
  local prof; prof="$(proj_field "$PROJECT" 3)"; [ -n "$prof" ] || prof="${PROFILE:-work}"
  CFG_DIR="$(profile_dir "$prof")"
  # work keeps the bare cf-<project> socket (back-compat); other profiles are
  # namespaced so a same-named project in another profile can't collide.
  case "$prof" in work|default) SOCK="cf-$PROJECT" ;; *) SOCK="cf-$prof-$PROJECT" ;; esac
  export CLAUDE_CONFIG_DIR="$CFG_DIR" CLAUDE_FLEET_DIR="$CFG_DIR/fleet" \
         CLAUDE_FLEET_PROFILE="$prof" CLAUDE_FLEET_SCOPE="$PROJECT" \
         CLAUDE_FLEET_ROOT="$PROJECT_ROOT" CLAUDE_FLEET_SOCK="$SOCK"
  mkdir -p "$CFG_DIR/fleet" 2>/dev/null
}

# Keep a budget governor alive for this project's fleet — a DUMB non-Claude loop
# that parks workers as the shared account nears its usage ceiling (see
# bin/fleet-governor). It must NOT be the master: the lead is on the same account
# and stalls at the same time, so metering has to run outside Claude. Singleton per
# project; opt out with CLAUDE_FLEET_GOVERNOR=off, watch-only with =dry.
ensure_governor() {
  local mode="${CLAUDE_FLEET_GOVERNOR:-on}"
  case "$mode" in 0|off|no|false) return 0 ;; esac
  local pidf="$CFG_DIR/fleet/$PROJECT.governor.pid" logf="$CFG_DIR/fleet/$PROJECT.governor.log"
  # already running for this project?
  if [ -f "$pidf" ] && kill -0 "$(cat "$pidf" 2>/dev/null)" 2>/dev/null; then return 0; fi
  local dry=""; [ "$mode" = "dry" ] && dry="--dry-run"
  CLAUDE_FLEET_DIR="$CFG_DIR/fleet" nohup "$BIN_DIR/fleet-governor" -s "$SOCK" $dry >>"$logf" 2>&1 &
  echo $! > "$pidf"
}

# the "master" lead session runs in the project's main checkout. From inside it,
# `C-a s` writes a "<socket>.goto" marker (see tmux/cf.tmux.conf) then detaches;
# we read that marker here to decide where to go next: the grid, or (on a plain
# `/C-a g detach) back to Projects. Sets MASTER_GOTO for the caller.
enter_master() {
  local main="$PROJECT_ROOT/$PROJECT"
  [ -d "$main/.git" ] || main="$(find "$PROJECT_ROOT" -maxdepth 1 -type d -exec test -e '{}/.git' ';' -print 2>/dev/null | head -1)"
  [ -n "$main" ] && [ -d "$main" ] || main="$PROJECT_ROOT"
  TM has-session -t master 2>/dev/null || \
    TM new-session -d -s master -c "$main" -e "CLAUDE_CONFIG_DIR=$CFG_DIR" -e "CLAUDE_FLEET_SOCK=$SOCK" "exec claude-here master"
  TM source-file "$CONF" 2>/dev/null || true           # refresh bindings/status on the live server
  ensure_governor                                       # budget backpressure for this fleet (non-Claude, singleton)
  # master's status-left names the project it leads + its live worker count
  # (project/socket baked in as literals; #() runs the helper on the status interval)
  TM set-option -t master status-left \
    "#[bg=colour148,fg=colour16,bold] ● master · #($BIN_DIR/fleet-statusbar '$PROJECT' '$SOCK') #[bg=colour236,fg=colour148,nobold]▏" 2>/dev/null || true
  local marker; marker="$(TM display-message -t master -p '#{socket_path}' 2>/dev/null).goto"
  rm -f "$marker" 2>/dev/null                          # clear any stale signal
  TM attach -t master 2>/dev/null || true; _clear
  MASTER_GOTO="$(cat "$marker" 2>/dev/null)"; rm -f "$marker" 2>/dev/null
}

# the session grid ⇄ attach loop for the current project; returns on back/quit
grid_loop() {
  local choice name cwd base i last=""   # last = the session we just left, so the grid re-selects it
  while true; do
    _clear
    choice="$(node "$GRID" "$SOCK" "$CONF" --select "$last" </dev/tty)" || true
    tmux -L "$SOCK" has-session 2>/dev/null && TM source-file "$CONF" 2>/dev/null || true
    case "$choice" in
      ""|back) return ;;
      attach${US}*) name="${choice#attach${US}}"; last="$name"; TM attach -t "$name" 2>/dev/null || true; _clear ;;
      new${US}*)
        cwd="${choice#new${US}}"; base="$(basename "$cwd")"; name="$base"; i=2
        while TM has-session -t "$name" 2>/dev/null; do name="$base-$i"; i=$((i + 1)); done
        TM new-session -d -s "$name" -c "$cwd" -e "CLAUDE_CONFIG_DIR=$CFG_DIR" -e "CLAUDE_FLEET_SOCK=$SOCK" "exec claude-here \"$name\""
        last="$name"; TM attach -t "$name" 2>/dev/null || true; _clear ;;
      newfresh${US}*)
        cwd="${choice#newfresh${US}}"; base="$(basename "$cwd")"; name="$base~2"; i=2
        while TM has-session -t "$name" 2>/dev/null; do i=$((i + 1)); name="$base~$i"; done
        TM new-session -d -s "$name" -c "$cwd" -e "CLAUDE_CONFIG_DIR=$CFG_DIR" -e "CLAUDE_FLEET_SOCK=$SOCK" -e "CLAUDE_FLEET_FRESH=1" "exec claude-here \"$name\""
        last="$name"; TM attach -t "$name" 2>/dev/null || true; _clear ;;
    esac
  done
}

# --- profile scope --------------------------------------------------------------
# `claude-fleet [profile]` gives each profile its own projects list
# (~/.config/claude-fleet/projects.<profile>) AND its own Claude config dir
# (~/.claude-<profile>). A bare arg that names a known WORK project still jumps
# straight into it (back-compat).
WORK_CFG="$HOME/.config/claude-fleet/projects"
PROFILE="work"; JUMP=""
if [ -n "${1:-}" ] && [ "${1#--}" = "$1" ]; then
  if awk -F'\t' -v n="$1" '$1==n{f=1} END{exit !f}' "$WORK_CFG" 2>/dev/null; then
    JUMP="$1"                          # known work project -> jump into it
  else
    PROFILE="$1"                       # otherwise the arg selects a profile
  fi
fi
case "$PROFILE" in
  work|default) PROJECTS_CFG="$WORK_CFG" ;;
  *)            PROJECTS_CFG="$HOME/.config/claude-fleet/projects.$PROFILE" ;;
esac
export CLAUDE_FLEET_PROJECTS="$PROJECTS_CFG" CLAUDE_FLEET_PROFILE="$PROFILE"

ensure_projects

# jump straight into a project (claude-fleet <project> [--plain])
PROJECT=""
if [ -n "$JUMP" ]; then
  set_project "$JUMP"
  [ "${2:-}" = "--plain" ] && exec node "$GRID" "$SOCK" "$CONF" --plain
fi

_clear
LAST_PROJECT=""    # the project we last stepped out of — Projects re-selects it
while true; do
  # LEVEL 0 — pick a project
  if [ -z "$PROJECT" ]; then
    sel="$(node "$GRID" - --screen projects --select "$LAST_PROJECT" </dev/tty)" || true; _clear
    case "$sel" in
      "") break ;;                                   # quit
      addproject)
        p="$(node "$GRID" - --screen addproject </dev/tty)" || true; _clear
        p="${p#newproject${US}}"
        if [ -n "$p" ] && [ "$p" != "newproject" ] && [ -d "$p" ]; then
          nm="$(basename "$p")"
          awk -F'\t' -v n="$nm" '$1==n{f=1} END{exit !f}' "$PROJECTS_CFG" 2>/dev/null \
            || printf '%s\t%s\t%s\n' "$nm" "$p" "$PROFILE" >> "$PROJECTS_CFG"
          set_project "$nm"
        fi ;;
      project${US}*) set_project "${sel#project${US}}" ;;
    esac
    [ -z "$PROJECT" ] && continue
  fi

  # LEVEL 1 — Master Claude (⏎ on a project lands straight here). From master:
  #   C-a s      -> the sessions grid; leaving the grid returns here to master
  #   ` / C-a g  -> back to the Projects picker
  MASTER_GOTO=""
  enter_master
  if [ "$MASTER_GOTO" = "grid" ]; then
    grid_loop
  else
    LAST_PROJECT="$PROJECT"   # remember it so the Projects picker re-selects it
    PROJECT=""
  fi
done
