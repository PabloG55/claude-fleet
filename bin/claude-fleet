#!/usr/bin/env bash
# claude-fleet — a single-pane grid that holds all the Claude sessions in the
# current zellij session. Run this as the one pane in a zellij session:
#
#   grid (fleet-grid.mjs)  ⇄  tmux attach  (you inside a live session)
#
# tmux is the hidden substrate (one isolated server per zellij session) that
# keeps every session alive in the background. Node draws the grid; tmux does
# all the PTY work. Detach from a session (prefix C-a, then g) to return here.
#
#   claude-fleet            interactive grid loop
#   claude-fleet --plain    one-shot non-interactive list (for scripts)
set -uo pipefail

# Resolve this script through the ~/.local/bin symlink to find the repo root.
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  target="$(readlink "$src")"
  case "$target" in /*) src="$target" ;; *) src="$(dirname "$src")/$target" ;; esac
done
BIN_DIR="$(cd "$(dirname "$src")" && pwd)"
REPO="$(cd "$BIN_DIR/.." && pwd)"
GRID="$BIN_DIR/fleet-grid.mjs"
CONF="$REPO/tmux/cf.tmux.conf"

command -v node  >/dev/null 2>&1 || { echo "claude-fleet: node is required"; exit 1; }
command -v tmux  >/dev/null 2>&1 || { echo "claude-fleet: tmux is required (brew install tmux)"; exit 1; }

# --- profile: which Claude config dir / account this fleet drives ------------
#   claude-fleet            -> work     (~/.claude)
#   claude-fleet personal   -> personal (~/.claude-personal)
#   claude-fleet <name>     -> ~/.claude-<name>
PROFILE="work"
case "${1:-}" in
  ""|--*) ;;                 # no profile given (or the arg is a flag like --plain)
  *) PROFILE="$1"; shift ;;
esac
case "$PROFILE" in
  work|default) PROFILE="work"; CFG_DIR="$HOME/.claude" ;;
  *)            CFG_DIR="$HOME/.claude-$PROFILE" ;;
esac
# Everything downstream (grid, hooks, spawned sessions) keys off this config dir.
export CLAUDE_CONFIG_DIR="$CFG_DIR"
export CLAUDE_FLEET_DIR="$CFG_DIR/fleet"
export CLAUDE_FLEET_PROFILE="$PROFILE"
mkdir -p "$CFG_DIR/fleet" 2>/dev/null

Z="${ZELLIJ_SESSION_NAME:-${CLAUDE_FLEET_SCOPE:-default}}"
export CLAUDE_FLEET_SCOPE="$Z"
# work keeps the plain socket (no churn to existing fleets); others are namespaced.
if [ "$PROFILE" = "work" ]; then SOCK="cf-$Z"; else SOCK="cf-$PROFILE-$Z"; fi
export CLAUDE_FLEET_SOCK="$SOCK"   # so sessions know their fleet (fleet-send/list/read)
US=$'\x1f'
TM() { tmux -L "$SOCK" -f "$CONF" "$@"; }

if [ "${1:-}" = "--plain" ]; then
  exec node "$GRID" "$SOCK" "$CONF" --plain
fi

while true; do
  choice="$(node "$GRID" "$SOCK" "$CONF" </dev/tty)" || true
  # keep the running server's options/bindings in sync with the repo config
  tmux -L "$SOCK" has-session 2>/dev/null && TM source-file "$CONF" 2>/dev/null || true
  case "$choice" in
    "")
      break
      ;;
    attach${US}*)
      name="${choice#attach${US}}"
      TM attach -t "$name" || true
      ;;
    new${US}*)
      cwd="${choice#new${US}}"
      base="$(basename "$cwd")"
      name="$base"; i=2
      while TM has-session -t "$name" 2>/dev/null; do name="$base-$i"; i=$((i + 1)); done
      TM new-session -d -s "$name" -c "$cwd" -e "CLAUDE_CONFIG_DIR=$CFG_DIR" -e "CLAUDE_FLEET_SOCK=$SOCK" "exec claude-here \"$name\""
      TM attach -t "$name" || true
      ;;
    newfresh${US}*)
      cwd="${choice#newfresh${US}}"
      base="$(basename "$cwd")"
      name="$base~2"; i=2
      while TM has-session -t "$name" 2>/dev/null; do i=$((i + 1)); name="$base~$i"; done
      TM new-session -d -s "$name" -c "$cwd" -e "CLAUDE_CONFIG_DIR=$CFG_DIR" -e "CLAUDE_FLEET_SOCK=$SOCK" -e "CLAUDE_FLEET_FRESH=1" "exec claude-here \"$name\""
      TM attach -t "$name" || true
      ;;
  esac
done
