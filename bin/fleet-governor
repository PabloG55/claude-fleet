#!/usr/bin/env bash
# fleet-governor [-s SOCKET] [options]
#
# Budget backpressure for a SINGLE-ACCOUNT fleet. Every worker + the lead drink
# from one usage pool, so wide fan-out drains it N x faster and all workers freeze
# at the ceiling together. This governor is a DUMB, non-Claude loop (zero Claude
# budget) ON PURPOSE: the lead runs on the same account and stalls too, so metering
# can't depend on it.
#
# Policy: let every worker run FULL TILT — no early throttling. Only step in at the
# ceiling: at/above --pause-at (default 98%) it NOTIFIES you and parks ALL workers
# at once; when the window recovers below --resume (default 90%) it resumes the ones
# IT parked (never a worker you paused by hand).
#
#   -s SOCKET      fleet socket (default: $CLAUDE_FLEET_SOCK)
#   --pause-at P   notify + park ALL workers at/above this 5h usage % (default 98)
#   --resume P     resume governor-parked workers below this % (default 90)
#   --interval N   seconds between ticks (default 60)
#   --once         run one tick and exit (for testing / cron)
#   --dry-run      log decisions, don't actually pause/resume/notify
set -uo pipefail

SOCK="${CLAUDE_FLEET_SOCK:-}"
INTERVAL=60; PAUSE_AT=98; RESUME=90; ONCE=0; DRY=0
COOLDOWN=900                          # min seconds between macOS "budget" alerts (anti-spam)
while [ $# -gt 0 ]; do
  case "$1" in
    -s)         SOCK="${2:?}"; shift 2 ;;
    --pause-at) PAUSE_AT="${2:?}"; shift 2 ;;
    --resume)   RESUME="${2:?}"; shift 2 ;;
    --interval) INTERVAL="${2:?}"; shift 2 ;;
    --once)     ONCE=1; shift ;;
    --dry-run)  DRY=1; shift ;;
    *) echo "fleet-governor: unknown arg $1" >&2; exit 1 ;;
  esac
done
[ -n "$SOCK" ] || { echo "fleet-governor: no socket (run inside a fleet session, or pass -s <socket>)" >&2; exit 1; }

FLEET_DIR="${CLAUDE_FLEET_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}/fleet}"
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"      # sibling fleet-pause / fleet-resume
PROJ="${SOCK#cf-}"
log() { echo "[fleet-governor $(date +%H:%M:%S)] $*"; }
INBOX="$FLEET_DIR/$SOCK.inbox"
inbox() { printf '%s\t%s\t%s\t%s\n' "$(date +%s)" "$1" "$2" "$3" >> "$INBOX" 2>/dev/null || true; }

LAST_NOTIFY=0
# "let me know" — a debounced macOS notification + the lead's inbox feed
notify() {
  local now msg="$1"; now="$(date +%s)"
  inbox "fleet" budget "$msg"
  [ "$DRY" = 1 ] && return 0
  if [ $(( now - LAST_NOTIFY )) -ge "$COOLDOWN" ] && command -v osascript >/dev/null 2>&1; then
    LAST_NOTIFY="$now"
    ( osascript -e "display notification \"$msg\" with title \"🔔 claude-fleet — $PROJ\" sound name \"Ping\"" >/dev/null 2>&1 & )
  fi
}

# The 5h usage % from a pane's status bar: the "NN%(" field. Excludes ctx:NN% (no
# paren after) and 7d:NN%( (colon-prefixed) by requiring a non-colon, non-digit char
# right before the number.
pct_of() {
  tmux -L "$SOCK" capture-pane -p -t "$1" 2>/dev/null \
    | grep -oE '[^:0-9][0-9]+%\(' | grep -oE '[0-9]+' | tail -1
}
# one shared account -> take the highest reading across all live panes
budget() {
  local max=0 p s
  for s in $(tmux -L "$SOCK" list-sessions -F '#{session_name}' 2>/dev/null); do
    p="$(pct_of "$s")"; [ -n "$p" ] && [ "$p" -gt "$max" ] && max="$p"
  done
  echo "$max"
}
# workers (never the lead), newest first
workers_newest_first() {
  tmux -L "$SOCK" list-sessions -F '#{session_created} #{session_name}' 2>/dev/null \
    | grep -vE ' master$' | sort -rn | awk '{print $2}'
}
is_parked()  { [ -f "$FLEET_DIR/$SOCK.$1.parked" ]; }
gov_parked() { is_parked "$1" && grep -q '^governor' "$FLEET_DIR/$SOCK.$1.parked" 2>/dev/null; }

tick() {
  local pct w active resumed n
  pct="$(budget)"
  if [ -z "$pct" ] || [ "$pct" -eq 0 ]; then log "no budget reading this tick"; return; fi

  # AT/ABOVE the ceiling -> notify + park ALL workers at once (once per episode)
  if [ "$pct" -ge "$PAUSE_AT" ]; then
    active=()
    for w in $(workers_newest_first); do is_parked "$w" || active+=("$w"); done
    n=${#active[@]}
    if [ "$n" -gt 0 ]; then
      log "budget ${pct}% >= ${PAUSE_AT}% -> parking ALL ${n} worker(s)"
      notify "budget ${pct}% — parked ${n} worker(s); auto-resume under ${RESUME}%"
      for w in "${active[@]}"; do
        log "  park $w"
        if [ "$DRY" != 1 ] && "$BIN_DIR/fleet-pause" -s "$SOCK" "$w" >/dev/null 2>&1; then
          printf 'governor %s\n' "$(date +%s)" > "$FLEET_DIR/$SOCK.$w.parked"
          inbox "$w" parked "governor: budget ${pct}% — ceiling, parked all"
        fi
      done
    else
      log "budget ${pct}% — all workers parked, holding for recovery"
    fi
    return
  fi

  # RECOVERED -> resume what WE parked (leave hand-paused workers alone)
  if [ "$pct" -lt "$RESUME" ]; then
    resumed=0
    for w in $(workers_newest_first); do
      if gov_parked "$w"; then
        log "budget ${pct}% < ${RESUME}% -> resume $w"
        if [ "$DRY" != 1 ]; then
          "$BIN_DIR/fleet-resume" -s "$SOCK" "$w" >/dev/null 2>&1
          inbox "$w" resumed "governor: budget ${pct}% — window recovered"
        fi
        resumed=1
      fi
    done
    [ "$resumed" = 0 ] && log "budget ${pct}% (healthy)"
    return
  fi

  # between RESUME and PAUSE_AT -> full throttle, do nothing
  log "budget ${pct}% (running full-throttle; ceiling ${PAUSE_AT}%)"
}

modelabel="ACTIVE (parks all at ceiling)"; [ "$DRY" = 1 ] && modelabel="dry-run (no pausing)"
log "started on $SOCK — $modelabel — pause-all>=${PAUSE_AT}%, resume<${RESUME}%, interval ${INTERVAL}s"
if [ "$ONCE" = 1 ]; then
  tick
else
  while true; do
    tmux -L "$SOCK" list-sessions >/dev/null 2>&1 || { log "fleet $SOCK is gone — governor exiting"; exit 0; }
    tick
    sleep "$INTERVAL"
  done
fi
