#!/usr/bin/env bash
# fleet-schedule <socket> <session> <target-epoch> <message...>
#
# Waits until <target-epoch>, then types <message> (default "continue") + Enter
# into the tmux <session> on <socket>. Meant to be spawned detached by the grid
# (press `s` on a card), but usable standalone too.
#
# Keeps the Mac awake while waiting (caffeinate) so the send actually fires.
# CAVEAT: reliable only if the machine is awake at the target time. caffeinate
# prevents *idle* sleep; a closed lid can still sleep. For a hard guarantee also:
#   sudo pmset schedule wake "MM/dd/yy HH:mm:ss"
set -uo pipefail

SOCK="${1:?socket}"; SESSION="${2:?session}"; TARGET="${3:?target-epoch}"; shift 3
MSG="${*:-continue}"
FLEET_DIR="${CLAUDE_FLEET_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}/fleet}"
MARK="$FLEET_DIR/$SESSION.sched"

now="$(date +%s)"
delay=$(( TARGET - now )); [ "$delay" -lt 0 ] && delay=0

# keep awake (idle-sleep only) for the lifetime of this waiter.
# NB: `if …; then caffeinate & fi` backgrounds ONLY caffeinate — writing it as
# `cmd && caffeinate &` would background the whole `&&` list in an extra bash
# subshell (a confusing second "bash fleet-schedule" in ps).
if command -v caffeinate >/dev/null 2>&1; then caffeinate -i -w "$$" & fi

sleep "$delay"

# only send if the session is still around
if tmux -L "$SOCK" has-session -t "$SESSION" 2>/dev/null; then
  # bracketed paste (multi-line safe) + a beat before Enter, else the Enter lands
  # inside the paste instead of submitting the turn
  tmux -L "$SOCK" set-buffer -b _fleet -- "$MSG"
  tmux -L "$SOCK" paste-buffer -p -d -b _fleet -t "$SESSION"
  sleep "${CLAUDE_FLEET_SUBMIT_DELAY:-0.5}"
  tmux -L "$SOCK" send-keys -t "$SESSION" Enter
fi
rm -f "$MARK" 2>/dev/null
