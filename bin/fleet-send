#!/usr/bin/env bash
# fleet-send [-s SOCKET] <session> <prompt...>
#
# Type <prompt> into another fleet session's Claude input and submit it. Meant
# to be called by a "lead" Claude session (via its Bash tool) to dispatch work
# to sibling sessions in the same fleet.
#
# Socket defaults to $CLAUDE_FLEET_SOCK (exported into every fleet session).
# Uses a bracketed paste so multi-line prompts go in as ONE message, then Enter.
set -uo pipefail

SOCK="${CLAUDE_FLEET_SOCK:-}"
# Prefer $TMUX (the live server this session runs in) over the env var — it's
# drift-proof; a long-running --resume/--fork Claude can hold a stale
# CLAUDE_FLEET_SOCK. Only when it names a cf-* fleet server; -s still overrides.
_t="${TMUX:-}"; case "${_t##*/}" in cf-*) SOCK="${_t%%,*}"; SOCK="${SOCK##*/}" ;; esac
if [ "${1:-}" = "-s" ]; then SOCK="${2:-}"; shift 2; fi
SESSION="${1:-}"; shift || true
MSG="$*"

[ -n "$SOCK" ]    || { echo "fleet-send: no socket (run inside a fleet session, or pass -s <socket>)" >&2; exit 1; }
[ -n "$SESSION" ] || { echo "fleet-send: usage: fleet-send [-s socket] <session> <prompt>" >&2; exit 1; }
[ -n "$MSG" ]     || { echo "fleet-send: empty prompt" >&2; exit 1; }
tmux -L "$SOCK" has-session -t "$SESSION" 2>/dev/null \
  || { echo "fleet-send: no session '$SESSION' on $SOCK (try: fleet-list)" >&2; exit 1; }

# Is the target mid-turn right now? Read the LIVE pane (Claude's working spinner),
# not the status file — the file can be stale, and a wrong guess here is harmless
# but a wrong "queued" note is confusing.
busy() { tmux -L "$SOCK" capture-pane -p -t "$SESSION" 2>/dev/null \
  | grep -qE '(…|\.\.\.) ?\([0-9]+[ms]|↓ ?[0-9.,]+ ?[km]? ?tokens|esc to interrupt'; }
pre_busy=no; busy && pre_busy=yes
[ "$pre_busy" = yes ] && echo "fleet-send: note — '$SESSION' is working; your prompt will queue after this turn." >&2

# Bracketed paste keeps a multi-line prompt as ONE message; then submit. The race
# (why a naive send sometimes silently fails): an Enter sent before the bracketed
# paste has finished rendering is swallowed as a newline instead of submitting. So
# wait for the paste to land, submit, then VERIFY the turn actually started (the
# pane flips to the spinner) and re-Enter if it didn't.
tmux -L "$SOCK" set-buffer -b _fleet -- "$MSG"
tmux -L "$SOCK" paste-buffer -p -d -b _fleet -t "$SESSION"

# wait for the paste to appear in the pane before pressing Enter (fall back ~2s)
probe="$(printf '%s' "$MSG" | tr '\n\r\t' '   ' | sed 's/  */ /g')"; probe="${probe: -24}"
for _ in $(seq 1 20); do
  tmux -L "$SOCK" capture-pane -p -t "$SESSION" 2>/dev/null | grep -qF -- "$probe" && break
  sleep 0.1
done

# Confirm the turn actually started. The RELIABLE signal is our pasted probe
# LEAVING Claude's input box: that catches a turn that finishes before any spinner
# renders (a fast reply) AND a turn that thinks a while before one appears (Opus
# extended thinking); a live spinner counts too. Watching only the spinner over a
# short window is what produced false "no turn started" warnings and a flurry of
# stray Enters fired into an already-running turn.
#
# in_input: 0 = probe still sitting in the input box; 1 = box present, probe gone
# (submitted); 2 = no box found (unknown → fall back to the spinner).
in_input() {
  local pane; pane="$(tmux -L "$SOCK" capture-pane -p -t "$SESSION" 2>/dev/null)"
  printf '%s\n' "$pane" | awk -v p="$probe" '
    { l[NR]=$0 } /╰/ { c=NR }
    END { if(!c) exit 2; for(i=c-1;i>=1;i--) if(l[i]~/╭/){o=i;break}
          for(i=o;i<=c;i++) if(index(l[i],p)) exit 0; exit 1 }'
}
submitted() { busy && return 0; in_input; [ "$?" = 1 ]; }

if [ "$pre_busy" = yes ]; then
  # already mid-turn: the prompt just queues into the box; one submit is enough
  sleep "${CLAUDE_FLEET_SUBMIT_DELAY:-0.4}"
  tmux -L "$SOCK" send-keys -t "$SESSION" Enter
  echo "fleet-send: → $SESSION (queued)"
else
  tmux -L "$SOCK" send-keys -t "$SESSION" Enter
  ok=no; renudged=no
  for i in $(seq 1 40); do                      # up to ~8s, but breaks as soon as confirmed
    submitted && { ok=yes; break; }
    # a swallowed Enter (the paste/Enter race) leaves the probe in the box — nudge
    # exactly ONCE more after ~1.6s; never spam Enter into a live turn
    if [ "$i" = 8 ] && [ "$renudged" = no ]; then
      in_input; [ "$?" = 0 ] && { tmux -L "$SOCK" send-keys -t "$SESSION" Enter; renudged=yes; }
    fi
    sleep 0.2
  done
  [ "$ok" = yes ] && echo "fleet-send: → $SESSION" \
                  || echo "fleet-send: → $SESSION (warning: could not confirm submit — verify it landed)" >&2
fi

# CF-6: record the dispatched task in the manifest so fleet-worktrees' TASK column
# reflects fleet-send work too (not just fleet-spawn --prompt). Keyed by the target's
# worktree path, matching fleet-spawn. Best-effort; never affects the send result.
FLEET_DIR="${CLAUDE_FLEET_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}/fleet}"
MANIFEST="$FLEET_DIR/$SOCK.manifest.tsv"
cwd="$(tmux -L "$SOCK" display-message -p -t "$SESSION" '#{pane_current_path}' 2>/dev/null)"
if [ -n "$cwd" ]; then
  subject="$(printf '%s' "$MSG" | tr '\n\r\t' '   ' | sed 's/^ *//' | cut -c1-200)"
  br="$(git -C "$cwd" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '-')"
  mtmp="$MANIFEST.$$.tmp"; mkdir -p "$FLEET_DIR" 2>/dev/null
  { [ -f "$MANIFEST" ] && awk -F'\t' -v w="$cwd" '$1!=w' "$MANIFEST"
    printf '%s\t%s\t%s\t%s\n' "$cwd" "$SESSION" "$br" "$subject"; } >"$mtmp" 2>/dev/null \
    && mv -f "$mtmp" "$MANIFEST" 2>/dev/null || rm -f "$mtmp" 2>/dev/null
fi
