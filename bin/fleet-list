#!/usr/bin/env bash
# fleet-list [-s SOCKET]
#
# List the sessions in this fleet with their status — so a lead session can see
# which siblings exist and whether they're free. Socket defaults to
# $CLAUDE_FLEET_SOCK.
set -uo pipefail

SOCK="${CLAUDE_FLEET_SOCK:-}"
# Prefer $TMUX (the live server this session runs in) over the env var — it's
# drift-proof; a long-running --resume/--fork Claude can hold a stale
# CLAUDE_FLEET_SOCK. Only when it names a cf-* fleet server; -s still overrides.
_t="${TMUX:-}"; case "${_t##*/}" in cf-*) SOCK="${_t%%,*}"; SOCK="${SOCK##*/}" ;; esac
if [ "${1:-}" = "-s" ]; then SOCK="${2:-}"; shift 2; fi
[ -n "$SOCK" ] || { echo "fleet-list: no socket (run inside a fleet session, or pass -s <socket>)" >&2; exit 1; }

FLEET_DIR="${CLAUDE_FLEET_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}/fleet}"
SELF="${CLAUDE_FLEET_SLOT:-}"

names="$(tmux -L "$SOCK" list-sessions -F '#{session_name}' 2>/dev/null)"
[ -n "$names" ] || { echo "(no sessions on $SOCK)"; exit 0; }

printf '%-22s %-10s %s\n' "SESSION" "STATUS" ""
while IFS= read -r name; do
  [ -n "$name" ] || continue
  st="?"
  if command -v jq >/dev/null 2>&1; then
    st="$(for f in "$FLEET_DIR"/*.json; do jq -r --arg s "$name" 'select(.slot==$s)|[(.ts//0),.status]|@tsv' "$f" 2>/dev/null; done | sort -rn | head -1 | cut -f2)"
  fi
  # a parked worker's hook status is stale (Escape doesn't fire Stop) — the marker
  # is the truth, so report 'parked' to agree with fleet-worktrees (namespaced).
  [ -f "$FLEET_DIR/$SOCK.$name.parked" ] && st="parked"
  # ORPHAN: its git worktree was removed but the tmux session lingers, so its pane
  # cwd no longer exists. Surface it as dead (+ how to clean it) — it's effectively
  # gone; don't dispatch to it.
  cwd="$(tmux -L "$SOCK" display-message -p -t "$name" '#{pane_current_path}' 2>/dev/null)"
  { [ -n "$cwd" ] && [ ! -d "$cwd" ]; } && st="dead"
  mark=""
  # the caller is, by definition, alive and mid-turn (it's running this) — so its
  # own row showing a stale 'need-you' is just confusing. Label it plainly.
  if   [ "$name" = "$SELF" ]; then mark="(you)"; [ "$st" = "need-you" ] && st="working"
  elif [ "$st" = dead ];      then mark="worktree gone → fleet-stop $name"; fi
  printf '%-22s %-10s %s\n' "$name" "${st:-?}" "$mark"
done <<EOF
$names
EOF
